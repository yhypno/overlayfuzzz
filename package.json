{
  "name": "overlayfuzz",
  "version": "0.1.0",
  "description": "Lightweight desktop overlay with OCR hotkey capture (Exiled-Exchange-2-inspired tech stack).",
  "packageManager": "bun@1.1.0",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --config renderer/vite.config.ts",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build:renderer": "vite build --config renderer/vite.config.ts",
    "preview:renderer": "vite preview --config renderer/vite.config.ts",
    "typecheck:renderer": "vue-tsc --project renderer/tsconfig.json --noEmit"
  },
  "keywords": [
    "electron",
    "ocr",
    "overlay",
    "tesseract",
    "screenshot"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron": "^29.3.0",
    "jimp": "^0.22.10",
    "screenshot-desktop": "^1.15.0",
    "tesseract.js": "^5.1.0",
    "vue": "^3.4.0"
  },
  "optionalDependencies": {
    "electron-overlay-window": "latest",
    "uiohook-napi": "latest"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vue-tsc": "^2.0.0",
    "wait-on": "^8.0.0"
  }
}
